									"const jsonData = pm.response.json();",
									"if (jsonData.success) {",
									"    // Access Token is set via Cookies in our server implementation,",
									"    // but if we were to use Bearer headers, we would set it here:",
									"    // pm.environment.set(\"accessToken\", jsonData.data.accessToken);",
									"    console.log('Login successful');",
									"}"
								],
								"type": "text/javascript"
							}
						}
