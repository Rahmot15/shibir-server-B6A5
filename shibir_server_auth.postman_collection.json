		{
			"name": "Supporter Report",
			"item": [
				{
					"name": "Save/Update My Report",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const jsonData = pm.response.json();",
									"pm.test('Response success true', function () {",
									"    pm.expect(jsonData.success).to.eql(true);",
									"});",
									"if (jsonData?.data?.id) {",
									"    pm.collectionVariables.set('reportId', jsonData.data.id);",
									"    console.log('reportId set:', jsonData.data.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"month\": \"{{reportMonth}}\",\n    \"name\": \"Supporter Test User\",\n    \"school\": \"Dhaka College\",\n    \"numericEntries\": [\n        { \"metric\": \"quran\", \"day\": 1, \"value\": 12 },\n        { \"metric\": \"hadith\", \"day\": 1, \"value\": 2 },\n        { \"metric\": \"textbook\", \"day\": 2, \"value\": 1.5 },\n        { \"metric\": \"namazJamaat\", \"day\": 2, \"value\": 5 }\n    ],\n    \"checkboxEntries\": [\n        { \"metric\": \"class\", \"day\": 1, \"checked\": true },\n        { \"metric\": \"selfcrit\", \"day\": 2, \"checked\": true },\n        { \"metric\": \"sports\", \"day\": 3, \"checked\": false }\n    ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/supporter-reports/my",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"supporter-reports",
								"my"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get My Report History",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/supporter-reports/my/history",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
