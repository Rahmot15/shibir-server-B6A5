		{
			"name": "Note System",
			"item": [
				{
					"name": "Create Note",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data.id) {",
									"    pm.collectionVariables.set('noteId', jsonData.data.id);",
									"    console.log('noteId set:', jsonData.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"My First Note\",\n    \"content\": {\n        \"type\": \"doc\",\n        \"content\": [\n            {\n                \"type\": \"paragraph\",\n                \"content\": [\n                    { \"type\": \"text\", \"text\": \"This is a test note created via Postman.\" }\n                ]\n            }\n        ]\n    }\n}",
							"options": {
