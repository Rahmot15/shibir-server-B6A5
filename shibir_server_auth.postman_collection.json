								"my",
								"history"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get My Report By Month",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/supporter-reports/my/by-month?month={{reportMonth}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"supporter-reports",
								"my",
								"by-month"
							],
							"query": [
								{
									"key": "month",
									"value": "{{reportMonth}}"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Get My Report By Id",
