enum Role {
  SUPPORTER // সমর্থক
  WORKER // কর্মী
  ASSOCIATE // সাথী
  MEMBER // সদস্য
  ADMIN // অ্যাডমিন
}

model User {
  id            String  @id @default(uuid())
  name          String?
  email         String  @unique
  password      String?
  emailVerified Boolean @default(false)
  image         String?

  role      Role     @default(SUPPORTER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes Note[]

  supporterReports SupporterReport[] @relation("SupporterReports")
  writtenAdvices   SupporterAdvice[] @relation("SupporterAdviceAuthor")
  workerReports    WorkerReport[]    @relation("WorkerReports")
  writtenWorkerAdvices WorkerAdvice[] @relation("WorkerAdviceAuthor")

  @@map("user")
}
